# Chess Analyzer Configuration
# Copy this file to .env and fill in required values

# === REQUIRED ===
# OpenAI API key for AI coaching features
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === OPTIONAL (defaults shown) ===
# Path to Stockfish binary (inside Docker container)
STOCKFISH_PATH=/usr/games/stockfish

# Stockfish analysis depth (lower = faster, higher = more accurate)
# Recommended: 12 for Raspberry Pi, 18+ for powerful machines
ANALYSIS_DEPTH=12

# SQLite database path (inside Docker container)
DATABASE_PATH=/app/data/app.db

# Default number of games to analyze
DEFAULT_GAME_COUNT=50

# OpenAI model to use for coaching
OPENAI_MODEL=gpt-4o-mini

# Number of recent chat messages to include as context
CHAT_HISTORY_LIMIT=10
